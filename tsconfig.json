{
	"include": ["source"],
	"compilerOptions":
	{
		"target": "es2019",
		"lib": ["es2020", "dom"],
		"module": "commonjs",
		"esModuleInterop": true,
		"allowJs": true,
		"checkJs": true,
		"declaration": true,
		"emitDeclarationOnly": true,
		"outDir": "types",
		"declarationMap": true,
		"resolveJsonModule": true
	}
}
